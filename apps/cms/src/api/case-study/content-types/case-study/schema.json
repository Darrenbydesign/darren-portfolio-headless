{
  "kind": "collectionType",
  "collectionName": "case_studies",
  "info": {
    "singularName": "case-study",
    "pluralName": "case-studies",
    "displayName": "Case Study"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "caseStudyCover": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "coverSize": {
      "type": "enumeration",
      "enum": [
        "small",
        "medium",
        "large",
        "zen"
      ],
      "default": "medium"
    },
    "heroMeta": {
      "type": "component",
      "repeatable": true,
      "component": "shared.hero-meta-chip"
    },
    "projectStats": {
      "type": "component",
      "repeatable": true,
      "component": "shared.detail-stat"
    },
    "description": {
      "type": "blocks"
    },
    "contentBlocks": {
      "type": "dynamiczone",
      "components": [
        "shared.content-rich-text",
        "shared.media",
        "shared.external-image",
        "shared.quote",
        "shared.slider",
        "shared.external-gallery"
      ]
    },
    "media": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "challenge": {
      "type": "blocks"
    },
    "solution": {
      "type": "blocks"
    },
    "results": {
      "type": "blocks"
    },
    "tools": {
      "type": "blocks"
    },
    "deliverableProgress": {
      "type": "component",
      "repeatable": true,
      "component": "shared.progress-item"
    },
    "datePublished": {
      "type": "date"
    }
  }
}
