---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Opening Case Study - Darren Sorrels Design" description="Redirecting to the requested case study." noindex>
  <section class="detail-page" aria-live="polite">
    <p>Opening the requested case study...</p>
    <noscript><p><a href="/work/">Browse all case studies</a></p></noscript>
  </section>
  <script slot="after-main" is:inline>
    const slug = new URLSearchParams(window.location.search).get("slug");
    window.location.replace(slug ? `/work/${encodeURIComponent(slug)}/` : "/work/");
  </script>
</BaseLayout>
