---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Case Study - Darren Sorrels Design">
  <article id="case-study-detail" class="detail-page panel" panel-type="detail">
    <p>Loading case study...</p>
  </article>

  <template id="case-study-detail-template">
    <a class="button back-link" button-style="outline" href="/work"
      >Back to Work</a
    >

    <header class="hero detail-hero" hero-layout="split" hero-density="medium">
      <div class="hero-copy">
        <p class="chip" chip-type="tag" chip-tone="inverse">Case Study</p>
        <h1 class="hero-title" data-study-title></h1>
        <p class="hero-text text-lead" data-study-date></p>
        <ul
          class="hero-meta"
          aria-label="Case study highlights"
          data-study-hero-meta
          hidden
        >
        </ul>
        <template data-study-hero-meta-template>
          <li class="chip" chip-style="outline"></li>
        </template>
      </div>

      <div
        class="panel hero-media"
        data-study-cover-shell
        media-density="medium"
      >
        <div class="hero-media-inner" data-study-cover-media>
          <span class="monogram" data-study-monogram></span>
        </div>
      </div>
    </header>

    <section class="detail-stats counter-list" aria-label="Case study snapshot">
      <header class="section-heading">
        <h2 class="section-title">Key Outcomes</h2>
      </header>
      <dl class="stats-section" data-study-stats></dl>
      <template data-study-stat-template>
        <div
          class="card detail-stat"
          card-type="stat"
          card-density="medium"
          card-effect="halftone"
        >
          <div class="card-content">
            <dt class="chip" chip-type="tag" data-study-stat-label></dt>
            <dd class="detail-stat-value">
              <strong class="card-value" data-study-stat-value></strong>
            </dd>
          </div>
        </div>
      </template>
    </section>

    <div class="case-layout detail-layout">
      <div class="case-main">
        <section
          class="detail-content counter-list"
          aria-label="Case study details"
          data-study-content
        >
          <section class="detail-section" aria-label="Description">
            <header data-study-description></header>
          </section>
          <section class="detail-section" aria-label="Challenge">
            <header data-study-challenge></header>
          </section>
          <section class="detail-section" aria-label="Solution">
            <header data-study-solution></header>
          </section>
          <section class="detail-section" aria-label="Results">
            <header data-study-results></header>
          </section>
          <section
            class="detail-media"
            aria-label="Project media"
            data-study-media-section
            hidden
          >
            <ul class="detail-media-list" data-study-media-list></ul>
          </section>
          <template data-study-media-template>
            <li class="detail-media-item">
              <figure class="media" media-variant="cover" media-density="small">
                <div data-study-media-frame></div>
              </figure>
            </li>
          </template>
        </section>
        <template data-content-block-media-template>
          <figure class="media" media-variant="cover" media-density="large">
            <div data-content-block-media-frame></div>
          </figure>
        </template>
        <template data-content-block-quote-template>
          <figure class="content-quote">
            <blockquote data-content-block-quote-body></blockquote>
            <figcaption data-content-block-quote-title hidden></figcaption>
          </figure>
        </template>
        <template data-content-block-slider-template>
          <section class="content-slider" aria-label="Image gallery">
            <ul class="content-slider-list" data-content-block-slider-list></ul>
          </section>
        </template>
        <template data-content-block-slider-item-template>
          <li class="content-slider-item">
            <figure class="media" media-variant="cover" media-density="small">
              <div data-content-block-slider-frame></div>
            </figure>
          </li>
        </template>
      </div>

      <aside class="case-sidebar">
        <section class="panel" panel-type="sidebar">
          <h2 class="panel-heading">Contributions</h2>
          <div class="progress-list" data-study-progress></div>
          <template data-study-progress-template>
            <div class="progress-item">
              <span data-study-progress-label></span>
              <output data-study-progress-value></output>
              <progress
                class="progress-bar"
                max="100"
                value="100"
                data-study-progress-bar></progress>
            </div>
          </template>
        </section>
        <section class="panel" panel-type="sidebar">
          <h2 class="panel-heading">Skills Used</h2>
          <div class="chip-group" data-study-stack></div>
        </section>
        <section class="panel" panel-type="cta">
          <h2 class="panel-heading">Work With Me</h2>
          <p class="panel-text">Let's build something as impactful as this.</p>
          <a class="button" button-style="filled" href="/#contact"
            >Hire Me Now</a
          >
        </section>
      </aside>
    </div>
  </template>
  <script slot="after-main" type="module" src="/js/workDetail.js"></script>
</BaseLayout>
