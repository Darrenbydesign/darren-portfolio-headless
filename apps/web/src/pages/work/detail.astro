---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="Case Study - Darren Sorrels Design">
  <article id="case-study-detail" class="detail-page panel" panel-type="detail">
    <p>Loading case study...</p>
  </article>

    <template id="case-study-detail-template">
      <a class="button back-link" button-style="outline" href="/work">Back to Work</a>

      <header class="panel hero detail-hero" panel-density="zen" hero-layout="split" hero-density="zen">
        <div class="hero-copy">
          <p class="chip" chip-type="tag" chip-tone="inverse">Case Study</p>
          <h1 class="hero-title" data-study-title></h1>
          <p class="hero-text text-lead" data-study-date></p>
          <div class="chip-group" chip-group-type="meta" data-study-tools-row hidden>
            <strong>Tools:</strong>
            <span class="chip-group" data-study-tools></span>
          </div>
        </div>
        <div class="panel hero-media" data-study-cover-shell media-density="medium">
          <div class="hero-media-inner" data-study-cover-media>
            <span class="monogram" data-study-monogram></span>
          </div>
        </div>
      </header>

      <section
        class="stats-section detail-stats counter-list"
        aria-label="Case study snapshot"
      >
        <article class="card counter-item" card-type="stat" card-density="large" card-effect="halftone">
          <p class="chip counter-label" chip-type="tag">Role</p>
          <strong class="card-value">UX</strong>
        </article>
        <article class="card counter-item" card-type="stat" card-density="large" card-effect="halftone">
          <p class="chip counter-label" chip-type="tag">Mode</p>
          <strong class="card-value">UI</strong>
        </article>
        <article class="card counter-item" card-type="stat" card-density="large" card-effect="halftone">
          <p class="chip counter-label" chip-type="tag">System</p>
          <strong class="card-value">DS</strong>
        </article>
        <article
          class="card counter-item"
          card-type="stat"
          card-density="large"
          card-effect="halftone"
          chip-tone="inverse"
        >
          <p class="chip counter-label" chip-type="tag">Launch</p>
          <strong class="card-value">01</strong>
        </article>
      </section>

      <div class="case-layout detail-layout">
        <div class="case-main">
          <section class="detail-content" data-study-content></section>
        </div>

        <aside class="case-sidebar">
          <section class="panel" panel-type="sidebar">
            <h2 class="panel-heading">Deliverables</h2>
            <div class="progress-list">
              <div class="progress-item">
                <span>Product Strategy</span><span>100%</span><i
                  class="progress-bar"></i>
              </div>
              <div class="progress-item">
                <span>UX Research</span><span>100%</span><i
                  class="progress-bar"></i>
              </div>
              <div class="progress-item">
                <span>Visual Design</span><span>100%</span><i
                  class="progress-bar"></i>
              </div>
            </div>
          </section>
          <section class="panel" panel-type="sidebar">
            <h2 class="panel-heading">Stack</h2>
            <div class="chip-group" data-study-stack></div>
          </section>
          <section class="panel" panel-type="cta">
            <h2 class="panel-heading">Work With Me</h2>
            <p class="panel-text">Let's build something as impactful as this.</p>
            <a class="button" button-style="filled" href="/#contact">Hire Me Now</a>
          </section>
        </aside>
      </div>
    </template>
  <script slot="after-main" type="module" src="/js/workDetail.js"></script>
</BaseLayout>
