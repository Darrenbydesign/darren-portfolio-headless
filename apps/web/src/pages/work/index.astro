---
import CaseStudyCard from "../../components/CaseStudyCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCaseStudies } from "../../lib/strapi";

const studies = await getCaseStudies();
---

<BaseLayout
  title="Work - Darren Sorrels Design"
  description="Selected UX, product design, and interaction design case studies by Darren Sorrels."
>
  <section class="work-page">
    <p class="chip" chip-type="tag">Selected Case Studies</p>
    <h2>Work</h2>
    <div class="card-group studies-grid">
      {
        studies.length ? (
          studies.map((study) => <CaseStudyCard study={study} />)
        ) : (
          <EmptyState kind="work" />
        )
      }
    </div>
  </section>
</BaseLayout>
