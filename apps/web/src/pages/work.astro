---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Work - Darren Sorrels Design">
  <main>
    <section class="work-page panel" panel-type="page" panel-style="halftone">
      <p class="tag">Selected Case Studies</p>
      <h2>Work</h2>
      <div id="case-studies" class="studies-grid"></div>
    </section>
    <template id="case-study-card-template">
      <article class="card" card-style="halftone" card-interactive="true">
        <h3 class="card-heading" data-study-title></h3>
        <p class="date" data-study-date></p>
        <p class="card-text" data-study-preview></p>
        <p class="meta-line"><strong>Tools:</strong> <span data-study-tools></span></p>
        <a class="button" data-study-link>View Case Study</a>
      </article>
    </template>
  </main>
</BaseLayout>
