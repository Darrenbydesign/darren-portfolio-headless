---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Darren Sorrels - UX Designer">
  <main class="portfolio-shell">
    <section
      id="home"
      class="panel hero"
      hero-layout="split"
      panel-style="halftone"
    >
      <div class="hero-copy">
        <p class="tag" tag-style="inverse">Chapter 01: Portfolio System</p>
        <h1 class="hero-title">UX Designer & Design Thinker</h1>
        <p class="hero-text text-lead">
          I am Darren Sorrels, User Experience & Interaction Designer crafting
          thoughtful digital experiences with research, interface design, and
          front-end polish.
        </p>
        <div class="hero-meta" aria-label="Portfolio highlights">
          <span class="chip chip-bordered">Kansas City</span>
          <span class="chip chip-bordered">UX / UI / Code</span>
        </div>
      </div>
      <div class="panel hero-media" aria-hidden="true">
        <div class="hero-media-inner">
          <span class="monogram">DS</span>
        </div>
      </div>
    </section>

    <section class="stats-section" aria-label="Portfolio impact stats">
      <article class="card" card-size="stat" card-style="halftone">
        <p class="tag">Experience Lens</p>
        <strong class="card-value">UX</strong>
      </article>
      <article class="card" card-size="stat" card-style="halftone">
        <p class="tag">Build Fluency</p>
        <strong class="card-value">HTML</strong>
      </article>
      <article class="card" card-size="stat" card-style="halftone">
        <p class="tag">Creative Range</p>
        <strong class="card-value">4x</strong>
      </article>
      <article
        class="card"
        card-size="stat"
        card-style="halftone"
        tag-style="inverse"
      >
        <p class="tag">Design Mode</p>
        <strong class="card-value">Ink</strong>
      </article>
    </section>

    <div class="case-layout">
      <div class="case-main">
        <section id="services" class="section-grid" grid-columns="two">
          <header class="section-heading">
            <span class="section-number">01.</span>
            <h2 class="section-title">My Services</h2>
          </header>
          <hr />

          <article class="card" card-size="feature">
            <h3 class="card-heading intro-list-header">UX Design Strategy</h3>
            <p class="card-text text-lead">
              I work with you to discover the problems that really need to be
              solved for your target users. Once we discover the issues I help
              you to implement the best solution to solve that problem.
            </p>
          </article>

          <article class="card" card-size="feature">
            <h3 class="card-heading intro-list-header">Interaction Design</h3>
            <p class="card-text text-lead">
              I craft beautiful interfaces that will make your products work
              smoothly and provide delightful experiences the power of
              aesthetics and function combined.
            </p>
          </article>

          <article class="card" card-size="feature">
            <h3 class="card-heading intro-list-header">
              Front-End Development
            </h3>
            <p class="card-text text-lead">
              I bring the designs to life with code utilizing my skills with
              HTML/CSS/JS.
            </p>
          </article>

          <article class="card" card-size="feature">
            <h3 class="card-heading intro-list-header">Identity Design</h3>
            <p class="card-text text-lead">
              I provide design services necessary to communicate your brand
              identity to your customers which include logo design along with
              the collaterals the logo design would be used on.
            </p>
          </article>
        </section>

        <section id="designProcess" class="panel" panel-type="process">
          <header class="section-heading">
            <span class="section-number">02.</span>
            <h2 class="section-title">The Approach</h2>
          </header>
          <p class="text-lead">
            The work moves like a sequence of panels: research creates the
            scene, strategy gives it structure, and interaction design turns the
            moment into something people can feel.
          </p>
          <div class="section-grid" grid-columns="three">
            <article class="card" card-size="compact">
              <h3 class="card-heading">Understand</h3>
              <p class="card-text">
                By conducting user research I can understand your customers
                needs and help you provide the optimal experience for them with
                your product.
              </p>
            </article>
            <article class="card" card-size="compact">
              <h3 class="card-heading">Define</h3>
              <p class="card-text">
                I combine the research gathered to hone in the key pain points
                your customers are facing.
              </p>
            </article>
            <article class="card" card-size="compact">
              <h3 class="card-heading">Ideate</h3>
              <p class="card-text">
                This is where the "extra fun" happens. I generate ideas with you
                and shape them into clear product directions.
              </p>
            </article>
            <article class="card" card-size="compact">
              <h3 class="card-heading">Prototype</h3>
              <p class="card-text">
                We'll build out the ideas most likely to improve the experience
                your users have.
              </p>
            </article>
            <article class="card" card-size="compact">
              <h3 class="card-heading">Testing</h3>
              <p class="card-text">
                Those ideas need to be tested to prove whether they will achieve
                the business needs and the users needs.
              </p>
            </article>
            <article class="card" card-size="compact">
              <h3 class="card-heading">Implement</h3>
              <p class="card-text">
                Once we determine the winner through testing, we begin shipping
                the product out to customers.
              </p>
            </article>
          </div>
        </section>

        <section
          class="panel"
          panel-type="showcase"
          aria-label="Interface design system preview"
        >
          <div class="showcase-screen">
            <span class="showcase-line"></span>
            <span class="showcase-line"></span>
            <span class="showcase-line"></span>
          </div>
        </section>
      </div>

      <aside class="case-sidebar" aria-label="Portfolio sidebar">
        <section class="panel" panel-type="sidebar">
          <h2 class="panel-heading">Deliverables</h2>
          <div class="progress-list">
            <div class="progress-item">
              <span>Product Strategy</span><span>100%</span>
              <i class="progress-bar"></i>
            </div>
            <div class="progress-item">
              <span>UX Research</span><span>100%</span>
              <i class="progress-bar"></i>
            </div>
            <div class="progress-item">
              <span>Visual Design</span><span>100%</span>
              <i class="progress-bar"></i>
            </div>
          </div>
        </section>
        <section class="panel" panel-type="sidebar">
          <h2 class="panel-heading">Stack</h2>
          <div class="chip-list">
            <span class="chip">Figma</span>
            <span class="chip">Astro</span>
            <span class="chip">CSS</span>
            <span class="chip">JavaScript</span>
          </div>
        </section>
        <section class="panel" panel-type="cta">
          <h2 class="panel-heading">Work With Me</h2>
          <p class="panel-text">Let's build something as impactful as this.</p>
          <a class="button" href="#contact">Hire Me Now</a>
        </section>
      </aside>
    </div>

    <section id="blog" class="content-section blog">
      <h2>Latest Blog Posts</h2>
      <div id="blog-posts" class="posts-grid"></div>
      <template id="blog-card-template">
        <article class="card" card-style="halftone" card-interactive="true">
          <h3 class="card-heading" data-blog-title></h3>
          <p class="date" data-blog-date></p>
          <p class="card-text" data-blog-preview></p>
          <a class="button" data-blog-link>Read More</a>
        </article>
      </template>
    </section>

    <section id="work" class="content-section case-studies">
      <h2>Featured Work</h2>
      <div id="case-studies" class="studies-grid"></div>
      <template id="case-study-card-template">
        <article class="card" card-style="halftone" card-interactive="true">
          <h3 class="card-heading" data-study-title></h3>
          <p class="date" data-study-date></p>
          <p class="card-text" data-study-preview></p>
          <p class="meta-line">
            <strong>Tools:</strong>
            <span data-study-tools></span>
          </p>
          <a class="button" data-study-link>View Case Study</a>
        </article>
      </template>
    </section>

    <section id="contact" class="panel contact" panel-style="halftone">
      <h2>Get In Touch</h2>
      <form id="contact-form">
        <label class="field">
          <span>Name</span>
          <input
            class="field-control"
            type="text"
            id="name"
            placeholder="Your Name"
            required
          />
        </label>
        <label class="field">
          <span>Email</span>
          <input
            class="field-control"
            type="email"
            id="email"
            placeholder="Your Email"
            required
          />
        </label>
        <label class="field">
          <span>Message</span>
          <textarea
            class="field-control"
            control-type="multiline"
            id="message"
            placeholder="Your Message"
            required></textarea>
        </label>
        <button class="button" type="submit">Send Message</button>
      </form>
      <p id="form-status"></p>
    </section>
  </main>
</BaseLayout>
