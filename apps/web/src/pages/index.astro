---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogCard from "../components/BlogCard.astro";
import CaseStudyCard from "../components/CaseStudyCard.astro";
import EmptyState from "../components/EmptyState.astro";
import { getBlogPosts, getCaseStudies } from "../lib/strapi";

const [blogPosts, caseStudies] = await Promise.all([
  getBlogPosts(),
  getCaseStudies(),
]);
---

<BaseLayout
  title="Darren Sorrels - UX Designer"
  description="UX and interaction design portfolio for Darren Sorrels, featuring product strategy, research, interface design, and front-end work."
>
  <section
    id="home"
    class="panel hero"
    hero-layout="split"
    panel-effect="halftone"
    panel-density="zen"
    panel-shape="none"
    hero-density="zen"
  >
    <div class="hero-copy">
      <h1 class="hero-title">UX Designer & Design Thinker</h1>
      <p class="hero-text text-lead">
        I am Darren Sorrels, User Experience & Interaction Designer crafting
        thoughtful digital experiences with research, interface design, and
        front-end polish.
      </p>
      <div class="hero-meta" aria-label="Portfolio highlights">
        <span class="chip" chip-style="outline">Product Design</span>
        <span class="chip" chip-style="outline">User Experience</span>
        <span class="chip" chip-style="outline">UX Strategy</span>
        <span class="chip" chip-style="outline">UI Development</span>
      </div>
    </div>
    <div class="panel hero-media" aria-hidden="true">
      <div class="hero-media-inner">
        <figure class="monogram">
          <img
            class="logo-image"
            src="/assets/header_logo.svg"
            alt="Darren Sorrels Design Logo"
            width="200"
            height="200"
          />
        </figure>
      </div>
    </div>
  </section>

  <div class="counter-list">
    <section id="services" class="section-grid" grid-columns="two" counter-item>
      <header class="section-heading">
        <h2 class="section-title">My Services</h2>
      </header>
      <hr />

      <article class="card" card-type="feature" card-density="large">
        <div class="card-content">
          <h3 class="card-heading">UX Design Strategy</h3>
          <p class="card-text text-lead">
            I work smarter <em>with you</em>, to discover the problems that
            really need to be solved for your target users. Once, we discover
            the issues I help you to implement the best solution to solve that
            problem.
          </p>
        </div>
      </article>

      <article class="card" card-type="feature" card-density="large">
        <div class="card-content">
          <h3 class="card-heading">Interaction Design</h3>
          <p class="card-text text-lead">
            I craft beautiful interfaces that will make your products work
            smoothly and provide delightful experiences the power of aesthetics
            and function combined.
          </p>
        </div>
      </article>

      <article class="card" card-type="feature" card-density="large">
        <div class="card-content">
          <h3 class="card-heading">UI Development</h3>
          <p class="card-text text-lead">
            I bring the designs to life with code utilizing my skills with
            HTML/CSS/JS.
          </p>
        </div>
      </article>

      <article class="card" card-type="feature" card-density="large">
        <div class="card-content">
          <h3 class="card-heading">Identity Design</h3>
          <p class="card-text text-lead">
            I provide design services necessary to communicate your brand
            identity to your customers which include logo design along with the
            collaterals the logo design would be used on.
          </p>
        </div>
      </article>
    </section>

    <section id="designProcess" class="panel" panel-type="process" counter-item>
      <header class="section-heading">
        <h2 class="section-title">The Approach</h2>
      </header>
      <hr />
      <p class="text-lead">
        The work moves like a sequence of panels: research creates the scene,
        strategy gives it structure, and interaction design turns the moment
        into something people can feel.
      </p>
      <div class="section-grid" grid-columns="three">
        <article class="card" card-style="outline" card-density="small">
          <div class="card-content">
            <h3 class="card-heading">Understand</h3>
            <p class="card-text">
              By conducting user research I can understand your customers needs
              and help you provide the optimal experience for them with your
              product.
            </p>
          </div>
        </article>
        <article class="card" card-style="outline" card-density="small">
          <div class="card-content">
            <h3 class="card-heading">Define</h3>
            <p class="card-text">
              I combine the research gathered to hone in the key pain points
              your customers are facing.
            </p>
          </div>
        </article>
        <article class="card" card-style="outline" card-density="small">
          <div class="card-content">
            <h3 class="card-heading">Ideate</h3>
            <p class="card-text">
              This is where the magic happens. I generate ideas with you and
              shape them into clear product directions.
            </p>
          </div>
        </article>
        <article class="card" card-style="outline" card-density="small">
          <div class="card-content">
            <h3 class="card-heading">Prototype</h3>
            <p class="card-text">
              We'll build out the ideas most likely to improve the experience
              your users have.
            </p>
          </div>
        </article>
        <article class="card" card-style="outline" card-density="small">
          <div class="card-content">
            <h3 class="card-heading">Testing</h3>
            <p class="card-text">
              Those ideas need to be tested to prove whether they will achieve
              the business needs and the users needs.
            </p>
          </div>
        </article>
        <article class="card" card-style="outline" card-density="small">
          <div class="card-content">
            <h3 class="card-heading">Implement</h3>
            <p class="card-text">
              Once we determine the winner through testing, we begin shipping
              the product out to customers.
            </p>
          </div>
        </article>
      </div>
    </section>

    <section id="blog" class="content-section blog">
      <h2>Latest Blog Posts</h2>
      <div class="card-group posts-grid">
        {
          blogPosts.length ? (
            blogPosts.map((post) => <BlogCard post={post} />)
          ) : (
            <EmptyState kind="journal" />
          )
        }
      </div>
    </section>

    <section id="work" class="content-section case-studies">
      <h2>Featured Work</h2>
      <div class="card-group studies-grid">
        {
          caseStudies.length ? (
            caseStudies.map((study) => <CaseStudyCard study={study} />)
          ) : (
            <EmptyState kind="work" />
          )
        }
      </div>
    </section>

    <section id="contact" class="contact">
      <h2>Get In Touch</h2>
      <form
        id="contact-form"
        name="contact"
        method="POST"
        action="/?contact=success#contact"
        data-netlify="true"
        netlify-honeypot="bot-field"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p hidden>
          <label>
            Do not fill this out if you are human:
            <input name="bot-field" autocomplete="off" />
          </label>
        </p>
        <label class="field">
          <span>Name</span>
          <input
            class="field-control"
            type="text"
            id="name"
            name="name"
            placeholder="Your Name"
            autocomplete="name"
            required
          />
        </label>
        <label class="field">
          <span>Email</span>
          <input
            class="field-control"
            type="email"
            id="email"
            name="email"
            placeholder="Your Email"
            autocomplete="email"
            required
          />
        </label>
        <label class="field">
          <span>Message</span>
          <textarea
            class="field-control"
            field-variant="multiline"
            id="message"
            name="message"
            placeholder="Your Message"
            required></textarea>
        </label>
        <button class="button" type="submit">Send Message</button>
      </form>
      <p
        id="form-status"
        class="form-status"
        role="status"
        aria-live="polite"
        aria-atomic="true"
      ></p>
    </section>
    <script slot="after-main" type="module" src="/js/contact.js"></script>
  </div>
</BaseLayout>
