---
import BlogCard from "../../components/BlogCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getBlogPosts } from "../../lib/strapi";

const posts = await getBlogPosts();
---

<BaseLayout
  title="Journal - Darren Sorrels Design"
  description="Articles from Darren Sorrels about UX strategy, interaction design, research, and front-end craft."
>
  <section class="blog-page">
    <p class="chip" chip-type="tag">Notes and Process</p>
    <h2>Journal</h2>
    <div class="card-group posts-grid">
      {
        posts.length ? (
          posts.map((post) => <BlogCard post={post} />)
        ) : (
          <EmptyState kind="journal" />
        )
      }
    </div>
  </section>
</BaseLayout>
