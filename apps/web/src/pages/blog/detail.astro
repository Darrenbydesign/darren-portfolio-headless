---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Opening Blog Post - Darren Sorrels Design" description="Redirecting to the requested journal entry." noindex>
  <section class="detail-page" aria-live="polite">
    <p>Opening the requested blog post...</p>
    <noscript><p><a href="/blog/">Browse all journal entries</a></p></noscript>
  </section>
  <script slot="after-main" is:inline>
    const slug = new URLSearchParams(window.location.search).get("slug");
    window.location.replace(slug ? `/blog/${encodeURIComponent(slug)}/` : "/blog/");
  </script>
</BaseLayout>
