---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Blog Post - Darren Sorrels Design">
  <article id="blog-post-detail" class="detail-page panel" panel-type="detail">
    <p>Loading blog post...</p>
  </article>

  <template id="blog-detail-template">
    <a class="button" button-style="outline" href="/blog">Back to Journal</a>

    <header class="detail-header">
      <p class="chip" chip-type="tag">Journal Entry</p>
      <p class="chip" chip-type="date" data-blog-date></p>
      <h1 data-blog-title></h1>
      <ul
        class="hero-meta"
        aria-label="Blog post highlights"
        data-blog-hero-meta
        hidden
      >
      </ul>
      <template data-blog-hero-meta-template>
        <li class="chip" chip-style="outline"></li>
      </template>
      <p class="detail-excerpt" data-blog-excerpt hidden></p>
      <figure
        class="media detail-cover-media"
        media-variant="cover"
        media-density="medium"
        data-blog-cover-media
        hidden
      >
      </figure>
    </header>

    <div class="detail-content" data-blog-content></div>
  </template>
  <script slot="after-main" type="module" src="/js/blogDetail.js"></script>
</BaseLayout>
