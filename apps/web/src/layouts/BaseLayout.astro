---
const { title = "darren-portfolio-headless" } = Astro.props;
const strapiApiUrl =
  import.meta.env.PUBLIC_STRAPI_API_URL || "http://localhost:1337/api";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Epilogue:wght@700;800&family=Plus+Jakarta+Sans:wght@400;500;700&family=Space+Grotesk:wght@700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/css/main.css" />
  </head>
  <body>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary navigation">
        <a class="brand-mark" href="/" aria-label="Darren Sorrels Design">
          <img
            class="brand-logo"
            src="/assets/header_logo.svg"
            alt=""
            width="40"
            height="40"
          />
          <span class="visually-hidden">Darren Sorrels Design</span>
        </a>
        <ul class="site-nav-list">
          <li class="site-nav-item"><a class="site-nav-link" href="/">Home</a></li>
          <li class="site-nav-item"><a class="site-nav-link" href="/blog">Blog</a></li>
          <li class="site-nav-item"><a class="site-nav-link" href="/work">Work</a></li>
          <li class="site-nav-item"><a class="site-nav-link" href="/about">About</a></li>
          <li class="site-nav-item"><a class="site-nav-link" href="/#contact">Contact</a></li>
        </ul>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="footer-inner">
        <div>
          <p class="footer-brand">Darren Sorrels Design</p>
          <p class="footer-meta">&copy; 2026 - Crafted with Art & Science</p>
        </div>
        <ul class="footer-links" aria-label="Footer navigation">
          <li><a class="footer-link" href="/about">About</a></li>
          <li><a class="footer-link" href="/#contact">Contact</a></li>
        </ul>
      </div>
    </footer>

    <script define:vars={{ strapiApiUrl }}>
      window.DARREN_STRAPI_API_URL = strapiApiUrl;
    </script>
  </body>
</html>
