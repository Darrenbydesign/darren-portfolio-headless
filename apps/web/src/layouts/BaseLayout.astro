---
import "../styles/main.css";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
}

const {
  title = "Darren Sorrels Design",
  description = "UX and interaction design portfolio for Darren Sorrels.",
  noindex = false,
} = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin);
const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const isCurrentPage = (path: string) => currentPath === path;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Darren Sorrels Design" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <link rel="icon" href="/assets/logo-symbol.svg" type="image/svg+xml" />
    <script is:inline>
      (() => {
        const storageKey = "darren-theme";
        const storedTheme = (() => {
          try {
            return localStorage.getItem(storageKey);
          } catch {
            return null;
          }
        })();

        if (storedTheme === "light" || storedTheme === "dark") {
          document.documentElement.dataset.theme = storedTheme;
        }

        document.documentElement.dataset.activeTheme =
          storedTheme === "light" || storedTheme === "dark"
            ? storedTheme
            : window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Epilogue:wght@700;800&family=Plus+Jakarta+Sans:wght@400;500;700&family=Space+Grotesk:wght@700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main-content"> Skip to main content </a>
    <header class="site-header">
      <nav class="site-nav" aria-label="Primary navigation">
        <a class="brand-mark" href="/">
          <svg
            class="brand-logo"
            width="40"
            height="40"
            viewBox="0 0 200 200"
            aria-hidden="true"
            focusable="false"
          >
            <use href="/assets/logo-symbol.svg#brand-logo"></use>
          </svg>
          <span class="sr-only">Darren Sorrels Design</span>
        </a>
        <button
          class="button site-menu-button"
          type="button"
          button-style="outline"
          popovertarget="site-menu-popover"
          popovertargetaction="toggle"
          aria-controls="site-menu-popover"
          aria-expanded="false"
          aria-label="Open primary navigation menu"
        >
          <span class="site-menu-icon" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </span>
          <span>Menu</span>
        </button>
        <div class="site-menu-popover" id="site-menu-popover">
          <button
            class="button site-nav-close"
            type="button"
            button-style="text"
            popovertarget="site-menu-popover"
            popovertargetaction="hide"
          >
            Close<span class="sr-only"> mobile navigation menu</span>
          </button>
          <ul class="site-nav-list">
            <li class="site-nav-item">
              <a class="button site-nav-link" button-style="text" href="/" aria-current={isCurrentPage("/") ? "page" : undefined} data-menu-close>Home</a>
            </li>
            <li class="site-nav-item">
              <a class="button site-nav-link" button-style="text" href="/blog" aria-current={isCurrentPage("/blog") ? "page" : undefined} data-menu-close>Blog</a>
            </li>
            <li class="site-nav-item">
              <a class="button site-nav-link" button-style="text" href="/work" aria-current={isCurrentPage("/work") ? "page" : undefined} data-menu-close>Work</a>
            </li>
            <li class="site-nav-item">
              <a class="button site-nav-link" button-style="text" href="/about" aria-current={isCurrentPage("/about") ? "page" : undefined} data-menu-close>About</a>
            </li>
            <li class="site-nav-item">
              <a class="button site-nav-link" button-style="text" href="/#contact" data-menu-close>Contact</a
              >
            </li>
          </ul>
        </div>
      </nav>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <slot name="after-main" />

    <div class="floating-actions" role="group" aria-label="Display settings">
      <button
        class="button theme-toggle"
        type="button"
        button-style="outline"
        button-shape="circle"
        aria-label="Switch color theme"
        aria-pressed="false"
        data-theme-toggle
      >
        <span class="theme-toggle-icon" aria-hidden="true"></span>
      </button>
    </div>

    <footer class="site-footer">
      <div class="footer-inner">
        <div>
          <p class="footer-brand">Darren Sorrels Design</p>
          <p class="footer-meta">&copy; 2026 - Crafted with Art & Science</p>
        </div>
        <ul class="footer-links" aria-label="Footer navigation">
          <li><a class="footer-link" href="/about">About</a></li>
          <li><a class="footer-link" href="/#contact">Contact</a></li>
        </ul>
      </div>
    </footer>

    <script>
      const themeStorageKey = "darren-theme";
      const themeToggle = document.querySelector("[data-theme-toggle]");
      const themeMedia = window.matchMedia("(prefers-color-scheme: dark)");

      const readStoredTheme = () => {
        try {
          const theme = localStorage.getItem(themeStorageKey);
          return theme === "light" || theme === "dark" ? theme : null;
        } catch {
          return null;
        }
      };

      const writeStoredTheme = (theme) => {
        try {
          localStorage.setItem(themeStorageKey, theme);
        } catch {
          return;
        }
      };

      const getSystemTheme = () => (themeMedia.matches ? "dark" : "light");
      const getActiveTheme = () => readStoredTheme() || getSystemTheme();

      const syncThemeToggle = () => {
        const activeTheme = getActiveTheme();
        const nextTheme = activeTheme === "dark" ? "light" : "dark";

        document.documentElement.dataset.activeTheme = activeTheme;

        if (themeToggle instanceof HTMLButtonElement) {
          themeToggle.setAttribute(
            "aria-label",
            `Switch to ${nextTheme} mode`,
          );
          themeToggle.setAttribute(
            "aria-pressed",
            activeTheme === "dark" ? "true" : "false",
          );
          themeToggle.title = `Switch to ${nextTheme} mode`;
        }
      };

      if (themeToggle instanceof HTMLButtonElement) {
        themeToggle.addEventListener("click", () => {
          const nextTheme = getActiveTheme() === "dark" ? "light" : "dark";

          document.documentElement.dataset.theme = nextTheme;
          writeStoredTheme(nextTheme);
          syncThemeToggle();
        });
      }

      themeMedia.addEventListener("change", () => {
        if (!readStoredTheme()) {
          syncThemeToggle();
        }
      });

      syncThemeToggle();

      const siteMenuButton = document.querySelector(".site-menu-button");
      const siteMenuPopover = document.querySelector("#site-menu-popover");

      if (
        siteMenuButton instanceof HTMLButtonElement &&
        siteMenuPopover instanceof HTMLElement
      ) {
        const menuMedia = window.matchMedia("(width <= 768px)");
        const syncMenuMode = ({ matches: isPopoverMode } = menuMedia) => {
          if (isPopoverMode && !siteMenuPopover.hasAttribute("popover")) {
            siteMenuPopover.setAttribute("popover", "auto");
            return;
          }

          if (isPopoverMode) {
            return;
          }

          if (siteMenuPopover.matches(":popover-open")) {
            siteMenuPopover.hidePopover();
          }

          siteMenuPopover.removeAttribute("popover");
          siteMenuButton.setAttribute("aria-expanded", "false");
        };

        siteMenuPopover.addEventListener("toggle", () => {
          siteMenuButton.setAttribute(
            "aria-expanded",
            siteMenuPopover.matches(":popover-open") ? "true" : "false",
          );
        });

        siteMenuPopover
          .querySelectorAll("[data-menu-close]")
          .forEach((link) => {
            link.addEventListener("click", () => {
              if ("hidePopover" in siteMenuPopover) {
                siteMenuPopover.hidePopover();
              }
            });
          });

        syncMenuMode();
        menuMedia.addEventListener("change", syncMenuMode);
      }
    </script>
  </body>
</html>
