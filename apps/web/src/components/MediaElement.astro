---
import { getMediaUrl, unwrapMedia } from "../lib/content";
import { getStrapiOrigin } from "../lib/strapi";
import type { StrapiMedia } from "../lib/types";

interface Props {
  media?: StrapiMedia;
  alt?: string;
  eager?: boolean;
  captions?: StrapiMedia;
  captionsLanguage?: string;
  captionsLabel?: string;
}

const {
  media,
  alt,
  eager = false,
  captions,
  captionsLanguage = "en",
  captionsLabel = "English",
} = Astro.props;
const normalized = unwrapMedia(media);
const src = getMediaUrl(media, getStrapiOrigin());
const captionsSrc = getMediaUrl(captions, getStrapiOrigin());
const mime = normalized?.mime ?? "";
const alternativeText =
  alt ?? normalized?.alternativeText ?? normalized?.caption ?? "";
---

{
  src && mime.startsWith("video/") ? (
    <video src={src} controls playsinline muted preload="metadata">
      {captionsSrc && (
        <track
          kind="captions"
          src={captionsSrc}
          srclang={captionsLanguage}
          label={captionsLabel}
          default
        />
      )}
    </video>
  ) : src && mime.startsWith("audio/") ? (
    <audio src={src} controls preload="metadata"></audio>
  ) : src && mime && !mime.startsWith("image/") ? (
    <a class="media-link" href={src}>{alternativeText || "Open media"}</a>
  ) : src ? (
    <img
      src={src}
      alt={alternativeText}
      width={normalized?.width || undefined}
      height={normalized?.height || undefined}
      loading={eager ? "eager" : "lazy"}
      decoding="async"
      fetchpriority={eager ? "high" : "auto"}
    />
  ) : null
}
